#!/usr/bin/env python3
"""
MyCTL Daemon Entry Point (V2.5 - UV-Native)
This script is now launched exclusively via 'uv run', which handles
environment synchronization and python management out-of-band.
"""

import sys
import time
import asyncio
from pathlib import Path

# Ensure the daemon source root is in sys.path
DAEMON_DIR = Path(__file__).resolve().parent
if str(DAEMON_DIR) not in sys.path:
    sys.path.insert(0, str(DAEMON_DIR))

# Record boot time for uptime telemetry
BOOT_TIME = time.time()

async def main():
    """Core server initialization."""
    # Only import core modules when we are guaranteed to be in the correct environment
    import setproctitle
    from myctl.core.registry import CommandRegistry
    from myctl.core.app import DaemonServer

    # Initialize Process Identity
    setproctitle.setproctitle("myctld")

    # 1. Initialize Registry
    registry = CommandRegistry()

    # 2. Discover Plugins
    await registry.discover()

    # 3. Start Server (Socket binding & __DAEMON_READY__ signal happen here)
    server = DaemonServer(registry)
    await server.start()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass
